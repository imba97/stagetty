{
  "name": "stagetty",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "TTY stage renderer with rolling log output for CLI tools",
  "author": "imba97",
  "license": "MIT",
  "keywords": [
    "cli",
    "tty",
    "spinner",
    "terminal",
    "logs",
    "stage"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "nano-staged": "^0.9.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "unbuild": "^3.6.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
